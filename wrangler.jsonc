{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ntnu-mcp",
  "main": "src/server.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  // Public hostname (also reachable at ntnu-mcp.martin-s-aspas.workers.dev).
  // Declared here rather than only in the dashboard so deploys are
  // reproducible; requires the martinsundal.no zone on this account.
  "routes": [{ "pattern": "ntnu-mcp.martinsundal.no", "custom_domain": true }],
  // Workers Logs (invocation logs + console output + errors in the dashboard).
  // Free plan: 200k events/day, ~3-day retention, no overage billing possible.
  "observability": { "enabled": true },
  // The installed `agents` SDK (0.2.35) statically pulls in a dynamic
  // `import("ai")` from an unrelated AI-SDK-chat-client code path inside
  // `agents/mcp` (see shims/ai-stub.ts for the full story). `ai` is not a
  // real dependency of this Worker — NtnuMcp never reaches that code path —
  // so esbuild is pointed at a stub that only needs to exist, not to work.
  "alias": {
    "ai": "./shims/ai-stub.ts"
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "MCP_OBJECT",
        "class_name": "NtnuMcp"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["NtnuMcp"]
    }
  ]
}
